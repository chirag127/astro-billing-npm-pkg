---
/*
 * <Pricing /> — the 3-tier table (Free / Pro / Max) with a
 * monthly/yearly toggle and embedded <CheckoutButton /> islands.
 *
 * Mounted by oriz.in/pricing (and ONLY by oriz.in/pricing per the
 * single-domain Razorpay rule). Every other app's "Upgrade" link
 * redirects here.
 *
 * Tier data: FAMILY_TIERS from `../data/tiers.ts`.
 */
import { FAMILY_TIERS } from '../data/tiers.ts'
import CheckoutButton from './CheckoutButton.astro'
---

<section class="pricing">
  <div class="toggle-row">
    <button type="button" class="toggle active" data-interval="monthly">Monthly</button>
    <button type="button" class="toggle" data-interval="yearly">Yearly · save ~17%</button>
  </div>

  <div class="tier-grid">
    {FAMILY_TIERS.map((tier) => (
      <article class:list={['tier', tier.highlight && 'highlight']}>
        <h2 class="tier-name">{tier.name}</h2>

        <p class="price" data-interval="monthly">
          {tier.priceMonthly === 0 ? (
            <span class="big">Free</span>
          ) : (
            <><span class="big">₹{tier.priceMonthly}</span><span class="sub"> / mo</span></>
          )}
        </p>
        <p class="price hidden" data-interval="yearly">
          {tier.priceYearly === 0 ? (
            <span class="big">Free</span>
          ) : (
            <><span class="big">₹{tier.priceYearly}</span><span class="sub"> / yr</span></>
          )}
        </p>

        <ul class="perks">
          {tier.perks.map((p) => <li>{p}</li>)}
        </ul>

        <div class="cta-slot">
          {tier.slug === 'free' && (
            <a class="cta-link" href={tier.cta.href}>{tier.cta.label}</a>
          )}
          {tier.cta.planMonthly && (
            <div data-interval="monthly">
              <CheckoutButton planTier={tier.cta.planMonthly} label={`${tier.cta.label} ${tier.name} Monthly`} />
            </div>
          )}
          {tier.cta.planYearly && (
            <div data-interval="yearly" class="hidden">
              <CheckoutButton planTier={tier.cta.planYearly} label={`${tier.cta.label} ${tier.name} Yearly`} />
            </div>
          )}
        </div>
      </article>
    ))}
  </div>

  <p class="hint">
    Verified users may receive an offer at checkout. Cancel anytime.
    Test mode active — use Razorpay test card <code>4111 1111 1111 1111</code>.
  </p>
</section>

<script>
  // Wire the monthly/yearly toggle: swap visibility of price + button
  // blocks tagged with data-interval.
  const toggles = document.querySelectorAll<HTMLButtonElement>('.toggle')
  toggles.forEach((t) => {
    t.addEventListener('click', () => {
      const interval = t.dataset.interval
      toggles.forEach((x) => x.classList.toggle('active', x === t))
      document.querySelectorAll<HTMLElement>('[data-interval]').forEach((el) => {
        if (el.classList.contains('toggle')) return
        el.classList.toggle('hidden', el.dataset.interval !== interval)
      })
    })
  })
</script>

<style>
  .pricing { max-width: 1100px; margin: 0 auto; padding: 1rem 0 }
  .toggle-row {
    display: flex; justify-content: center; gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .toggle {
    border: 1px solid var(--rule, #ddd);
    background: transparent; color: inherit;
    padding: 0.5rem 1rem; font: inherit; cursor: pointer;
    border-radius: 4px;
  }
  .toggle.active {
    background: var(--ink, #111); color: var(--paper, #fff);
    border-color: var(--ink, #111);
  }
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .tier {
    border: 1px solid var(--rule, #ddd);
    background: var(--paper, #fff);
    padding: 1.5rem;
    display: flex; flex-direction: column; gap: 1rem;
  }
  .tier.highlight {
    border-color: var(--accent, #E0492F);
    border-width: 2px;
  }
  .tier-name {
    font-family: var(--font-display, inherit);
    font-size: 1.5rem; margin: 0; font-weight: 600;
  }
  .price .big {
    font-size: 2.25rem; font-weight: 700;
    font-family: var(--font-display, inherit);
  }
  .price .sub { color: var(--ink-mute, #666) }
  .perks {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.4rem;
    font-size: 0.9375rem; line-height: 1.5;
    flex: 1;
  }
  .perks li::before { content: '✓  '; color: var(--accent, #E0492F) }
  .cta-slot { margin-top: auto }
  .cta-link {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--ink, #111);
    color: var(--ink, #111);
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
  }
  .hidden { display: none !important }
  .hint {
    margin-top: 1.5rem; text-align: center;
    color: var(--ink-mute, #666); font-size: 0.875rem;
  }
  .hint code {
    background: var(--rule, #f0f0f0);
    padding: 0.125rem 0.375rem; border-radius: 3px;
    font-size: 0.8125rem;
  }
</style>
