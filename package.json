    "./razorpay-client": "./src/lib/razorpay-client.ts"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "dependencies": {
    "razorpay": "^2.9.6",
    "firebase-admin": "^13.0.0"
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "happy-dom": "^15.0.0",
    "typescript": "^5.6.0"
  }
