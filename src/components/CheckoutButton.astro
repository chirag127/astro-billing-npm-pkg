---
/*
 * <CheckoutButton planTier="pro_monthly" label="Subscribe" />
 *
 * Client-side island. On click:
 *   1. Check for cross-domain auth via the `oriz_auth` cookie at `.oriz.in`
 *      (set by account.oriz.in on sign-in). If absent → redirect to
 *      account.oriz.in/sign-in?return=<current-url>.
 *   2. POST /api/billing-create-subscription { planTier } with the cookie's
 *      idToken if present (server side validates via Firebase Admin REST).
 *   3. Get { subscription_id, key_id }
 *   4. Open Razorpay Checkout JS modal with that subscription_id.
 *
 * The Razorpay Checkout JS is injected once per page via a guarded
 * <script src="..."> below; if multiple <CheckoutButton /> instances
 * are rendered Astro de-dupes the import.
 *
 * Auth flow: we read the family-wide `oriz_auth` cookie set by
 * account.oriz.in. The cookie stores the Firebase ID token + user metadata.
 * No local Firebase SDK init required on the host page — just the cookie.
 */
interface Props {
  planTier: 'pro_monthly' | 'pro_yearly' | 'max_monthly' | 'max_yearly'
  label?: string
  class?: string
}

const { planTier, label = 'Subscribe', class: className } = Astro.props
---

<button
  type="button"
  class:list={['rzp-checkout-btn', className]}
  data-plan-tier={planTier}
>
  {label}
</button>

<script>
  const AUTH_ORIGIN = 'https://account.oriz.in'
  const AUTH_COOKIE = 'oriz_auth'

  interface AuthUser {
    uid?: string
    email?: string
    displayName?: string
    idToken?: string
    exp?: number
  }

  /** Read the family-wide auth cookie set by account.oriz.in. */
  function readAuthCookie(): AuthUser | null {
    const raw = document.cookie
      .split('; ')
      .find((row) => row.startsWith(`${AUTH_COOKIE}=`))
    if (!raw) return null
    try {
      const value = decodeURIComponent(raw.slice(AUTH_COOKIE.length + 1))
      const user = JSON.parse(value) as AuthUser
      if (user.exp && user.exp * 1000 < Date.now()) return null
      return user
    } catch {
      return null
    }
  }

  /** Bounce to central sign-in with a return URL. */
  function bounceToSignIn(): void {
    const ret = encodeURIComponent(window.location.href)
    window.location.href = `${AUTH_ORIGIN}/sign-in?return=${ret}`
  }

  // Razorpay Checkout SDK loader — idempotent across multiple buttons.
  function loadRazorpay(): Promise<void> {
    return new Promise((resolve, reject) => {
      // @ts-ignore — runtime global
      if (typeof window !== 'undefined' && (window as any).Razorpay) return resolve()
      const s = document.createElement('script')
      s.src = 'https://checkout.razorpay.com/v1/checkout.js'
      s.onload = () => resolve()
      s.onerror = () => reject(new Error('Failed to load Razorpay'))
      document.head.appendChild(s)
    })
  }

  document.querySelectorAll<HTMLButtonElement>('.rzp-checkout-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const planTier = btn.dataset.planTier

      // 1. Auth check via cross-domain cookie (set by account.oriz.in).
      const user = readAuthCookie()
      if (!user) {
        bounceToSignIn()
        return
      }

      btn.disabled = true
      btn.dataset.originalLabel = btn.textContent ?? ''
      btn.textContent = 'Loading…'

      try {
        await loadRazorpay()

        // 2. Create subscription server-side. Send idToken from cookie
        //    (if present) so the Pages Function can verify the user.
        const res = await fetch('/api/billing-create-subscription', {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
            authorization: user.idToken ? `Bearer ${user.idToken}` : '',
          },
          body: JSON.stringify({ planTier }),
        })
        if (!res.ok) {
          // Token expired? Cookie tampered? Bounce to sign-in.
          if (res.status === 401) {
            bounceToSignIn()
            return
          }
          throw new Error(`create-subscription returned ${res.status}`)
        }
        const { subscription_id, key_id } = await res.json()

        // 3. Open Razorpay modal.
        // @ts-ignore — Razorpay global from checkout.js
        const rzp = new (window as any).Razorpay({
          key: key_id,
          subscription_id,
          name: 'Oriz',
          description: 'Subscription',
          prefill: {
            email: user.email ?? '',
            name: user.displayName ?? '',
          },
          theme: { color: '#E0492F' },
          handler: () => {
            // Webhook is the source of truth — close modal + redirect.
            location.href = '/account?welcome=pro'
          },
          modal: {
            ondismiss: () => {
              btn.disabled = false
              btn.textContent = btn.dataset.originalLabel ?? 'Subscribe'
            },
          },
        })
        rzp.open()
      } catch (err) {
        console.error('[CheckoutButton]', err)
        btn.disabled = false
        btn.textContent = btn.dataset.originalLabel ?? 'Subscribe'
        alert('Checkout failed. Please try again.')
      }
    })
  })
</script>

<style>
  .rzp-checkout-btn {
    background: var(--accent, #E0492F);
    color: #fff;
    border: 0;
    padding: 0.625rem 1.25rem;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    border-radius: 4px;
    transition: opacity 0.15s ease;
  }
  .rzp-checkout-btn:hover { opacity: 0.92 }
  .rzp-checkout-btn:disabled { opacity: 0.6; cursor: wait }
</style>
